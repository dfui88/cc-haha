            "fileTriggers": {
                "pathPatterns": ["**/routes/**/*.ts", "**/test-*.js", "**/test-*.ts"],
                "contentPatterns": ["router\\.(get|post|put|delete|patch)", "app\\.(get|post|put|delete|patch)"]
            }
