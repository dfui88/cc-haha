        "keywords": ["设计页面", "UI设计", "界面", "landing", "hero", "bento", "动画", "前端设计", "视觉"],
        "intentPatterns": ["(设计|创建|制作).*?(页面|界面|UI|前端)", "(design|create).*?(landing|hero|page)"]
      }
    },
